{
  "compilerOptions": {
    // Base
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,

    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,

    // Not transpiling with Typescript
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "noEmit": true,

    // Building library monorepo
    "declaration": true,
    "composite": true,
    "sourceMap": true,
    "declarationMap": true,

    // Not running in DOM
    "lib": ["ES2022"]
  }
}
